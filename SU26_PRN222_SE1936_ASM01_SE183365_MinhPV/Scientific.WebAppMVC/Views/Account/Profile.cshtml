@model UsersHuyDd

@{
    ViewData["Title"] = "Profile";
    var roles = Model.RoleIdHuyDds.Select(x => x.RoleName);
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h1 class="h3 mb-0">Profile</h1>
                    <span class="badge bg-success">Active</span>
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-3">Full name</dt>
                    <dd class="col-sm-9">@Model.FullName</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Phone</dt>
                    <dd class="col-sm-9">@(Model.PhoneNumber ?? "N/A")</dd>

                    <dt class="col-sm-3">Organization</dt>
                    <dd class="col-sm-9">@(Model.Organization ?? "N/A")</dd>

                    <dt class="col-sm-3">Academic title</dt>
                    <dd class="col-sm-9">@(Model.AcademicTitle ?? "N/A")</dd>

                    <dt class="col-sm-3">Roles</dt>
                    <dd class="col-sm-9">@string.Join(", ", roles)</dd>

                    <dt class="col-sm-3">Created at</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
