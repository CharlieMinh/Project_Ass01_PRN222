@model Publisher
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<input asp-for="PublisherId" type="hidden" /><input asp-for="CreatedAt" type="hidden" />
<div class="mb-3"><label asp-for="PublisherName" class="form-label">Publisher name</label><input asp-for="PublisherName" class="form-control" /><span asp-validation-for="PublisherName" class="text-danger"></span></div>
<div class="mb-3"><label asp-for="Country" class="form-label"></label><input asp-for="Country" class="form-control" /></div>
<div class="mb-3"><label asp-for="WebsiteUrl" class="form-label">Website URL</label><input asp-for="WebsiteUrl" class="form-control" /></div>
<button type="submit" class="btn btn-primary">Save</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
