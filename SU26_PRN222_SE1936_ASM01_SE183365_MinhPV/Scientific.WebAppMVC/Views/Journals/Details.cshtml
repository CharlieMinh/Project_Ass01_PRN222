@model JournalsMinhPv
@{ ViewData["Title"] = "Journal Details"; }
<div class="d-flex justify-content-between mb-3"><h1 class="h3">Journal Details</h1><div><a asp-action="AssignCategories" asp-route-id="@Model.JournalIdMinhPv" class="btn btn-success">Assign Categories</a> <a asp-action="Edit" asp-route-id="@Model.JournalIdMinhPv" class="btn btn-primary">Edit</a> <a asp-action="Index" class="btn btn-outline-secondary">Back</a></div></div>
<dl class="row"><dt class="col-sm-3">Journal name</dt><dd class="col-sm-9">@Model.JournalName</dd><dt class="col-sm-3">Publisher</dt><dd class="col-sm-9">@(Model.Publisher?.PublisherName ?? "N/A")</dd><dt class="col-sm-3">Categories</dt><dd class="col-sm-9">@string.Join(", ", Model.CategoryIdMinhPvs.Select(x => x.CategoryName))</dd><dt class="col-sm-3">ISSN / EISSN</dt><dd class="col-sm-9">@($"{Model.Issn ?? "N/A"} / {Model.Eissn ?? "N/A"}")</dd><dt class="col-sm-3">Impact factor</dt><dd class="col-sm-9">@(Model.ImpactFactor?.ToString("0.###") ?? "N/A")</dd><dt class="col-sm-3">Ranking</dt><dd class="col-sm-9">@(Model.Ranking ?? "N/A")</dd><dt class="col-sm-3">Country</dt><dd class="col-sm-9">@(Model.Country ?? "N/A")</dd><dt class="col-sm-3">Papers</dt><dd class="col-sm-9">@Model.PapersBaoTgs.Count</dd></dl>
