@model IEnumerable<JournalsMinhPv>
@{ ViewData["Title"] = "Journals"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h3">Journals</h1><a asp-action="Create" class="btn btn-primary">Create Journal</a></div>
@if (TempData["SuccessMessage"] is string s){<div class="alert alert-success">@s</div>} @if (TempData["ErrorMessage"] is string e){<div class="alert alert-danger">@e</div>}
<form method="get" class="row g-2 mb-3"><div class="col-md-5"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search journal, ISSN, publisher" /></div><div class="col-auto"><button class="btn btn-outline-primary">Search</button></div><div class="col-auto"><a asp-action="Index" class="btn btn-outline-secondary">Reset</a></div></form>
<table class="table table-hover align-middle"><thead><tr><th>Name</th><th>Publisher</th><th>ISSN</th><th>Impact</th><th>Ranking</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>
@foreach (var item in Model){<tr><td>@item.JournalName</td><td>@(item.Publisher?.PublisherName ?? "N/A")</td><td>@(item.Issn ?? "N/A")</td><td>@(item.ImpactFactor?.ToString("0.###") ?? "N/A")</td><td>@(item.Ranking ?? "N/A")</td><td>@(item.IsActive ? "Active" : "Inactive")</td><td class="text-end"><a asp-action="Details" asp-route-id="@item.JournalIdMinhPv" class="btn btn-sm btn-outline-secondary">Details</a> <a asp-action="AssignCategories" asp-route-id="@item.JournalIdMinhPv" class="btn btn-sm btn-outline-success">Categories</a> <a asp-action="Edit" asp-route-id="@item.JournalIdMinhPv" class="btn btn-sm btn-outline-primary">Edit</a> <a asp-action="Delete" asp-route-id="@item.JournalIdMinhPv" class="btn btn-sm btn-outline-danger">Delete</a></td></tr>}
</tbody></table>
