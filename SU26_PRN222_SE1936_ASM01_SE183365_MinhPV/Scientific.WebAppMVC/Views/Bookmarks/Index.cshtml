@model BookmarksIndexViewModel

@{
    ViewData["Title"] = "My Bookmarks";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">My Bookmarks</h1>
        <p class="text-muted mb-0">Papers you saved for later reading.</p>
    </div>
    <a asp-controller="Papers" asp-action="Search" class="btn btn-outline-primary">Search Papers</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.Bookmarks.Any())
{
    <div class="alert alert-info">You have not bookmarked any papers yet.</div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var bookmark in Model.Bookmarks)
        {
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between gap-3">
                        <div>
                            <h2 class="h5 mb-2">
                                <a asp-controller="Papers" asp-action="Details" asp-route-id="@bookmark.PaperId" class="text-decoration-none">
                                    @bookmark.Title
                                </a>
                            </h2>
                            <div class="text-muted small">
                                Journal: @(bookmark.JournalName ?? "N/A")
                                <span class="mx-1">|</span>
                                Year: @(bookmark.PublicationYear?.ToString() ?? "N/A")
                                <span class="mx-1">|</span>
                                Citations: @bookmark.CitationCount
                                <span class="mx-1">|</span>
                                Saved: @bookmark.CreatedAt.ToString("yyyy-MM-dd")
                            </div>
                        </div>
                        @if (bookmark.IsOpenAccess)
                        {
                            <div>
                                <span class="badge text-bg-success">Open Access</span>
                            </div>
                        }
                    </div>
                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <a asp-controller="Papers" asp-action="Details" asp-route-id="@bookmark.PaperId" class="btn btn-sm btn-outline-primary">View Detail</a>
                        <form asp-controller="Bookmarks" asp-action="Remove" asp-route-paperId="@bookmark.PaperId" method="post" class="d-inline">
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
