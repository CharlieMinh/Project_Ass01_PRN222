@model FollowingIndexViewModel

@{
    ViewData["Title"] = "My Following";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">My Following</h1>
        <p class="text-muted mb-0">Keywords, topics, and journals you are tracking.</p>
    </div>
    <a asp-controller="Trends" asp-action="TrendingTopics" class="btn btn-outline-primary">Explore Trends</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <section class="border rounded p-3 h-100">
            <h2 class="h5 mb-3">Keywords</h2>
            @if (!Model.Keywords.Any())
            {
                <p class="text-muted mb-0">No followed keywords.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var item in Model.Keywords)
                    {
                        <div class="list-group-item px-0">
                            <div class="d-flex justify-content-between gap-2">
                                <div>
                                    <a asp-controller="Trends" asp-action="Keyword" asp-route-id="@item.Id" class="fw-semibold text-decoration-none">@item.Name</a>
                                    <div class="text-muted small">Since @item.FollowedAt.ToString("yyyy-MM-dd")</div>
                                </div>
                                <form asp-action="UnfollowKeyword" asp-route-keywordId="@item.Id" method="post">
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Unfollow</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>

    <div class="col-lg-4">
        <section class="border rounded p-3 h-100">
            <h2 class="h5 mb-3">Topics</h2>
            @if (!Model.Topics.Any())
            {
                <p class="text-muted mb-0">No followed topics.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var item in Model.Topics)
                    {
                        <div class="list-group-item px-0">
                            <div class="d-flex justify-content-between gap-2">
                                <div>
                                    <a asp-controller="Trends" asp-action="Topic" asp-route-id="@item.Id" class="fw-semibold text-decoration-none">@item.Name</a>
                                    <div class="text-muted small">Since @item.FollowedAt.ToString("yyyy-MM-dd")</div>
                                </div>
                                <form asp-action="UnfollowTopic" asp-route-topicId="@item.Id" method="post">
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Unfollow</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>

    <div class="col-lg-4">
        <section class="border rounded p-3 h-100">
            <h2 class="h5 mb-3">Journals</h2>
            @if (!Model.Journals.Any())
            {
                <p class="text-muted mb-0">No followed journals.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var item in Model.Journals)
                    {
                        <div class="list-group-item px-0">
                            <div class="d-flex justify-content-between gap-2">
                                <div>
                                    <div class="fw-semibold">@item.Name</div>
                                    <div class="text-muted small">Since @item.FollowedAt.ToString("yyyy-MM-dd")</div>
                                </div>
                                <form asp-action="UnfollowJournal" asp-route-journalId="@item.Id" method="post">
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Unfollow</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
</div>
