@model UsersHuyDd

@{
    ViewData["Title"] = "User Details";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">User Details</h1>
    <div>
        <a asp-action="AssignRoles" asp-route-id="@Model.UserIdHuyDd" class="btn btn-success">Assign Roles</a>
        <a asp-action="Edit" asp-route-id="@Model.UserIdHuyDd" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Full name</dt>
    <dd class="col-sm-9">@Model.FullName</dd>
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@(Model.PhoneNumber ?? "N/A")</dd>
    <dt class="col-sm-3">Organization</dt>
    <dd class="col-sm-9">@(Model.Organization ?? "N/A")</dd>
    <dt class="col-sm-3">Academic title</dt>
    <dd class="col-sm-9">@(Model.AcademicTitle ?? "N/A")</dd>
    <dt class="col-sm-3">Roles</dt>
    <dd class="col-sm-9">@string.Join(", ", Model.RoleIdHuyDds.Select(x => x.RoleName))</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Locked")</dd>
    <dt class="col-sm-3">Created</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Updated</dt>
    <dd class="col-sm-9">@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</dd>
</dl>
