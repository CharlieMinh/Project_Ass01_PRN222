@model IEnumerable<UsersHuyDd>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">Users</h1>
        <p class="text-muted mb-0">Manage accounts, status, and roles.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create User</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name, email, or organization" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Search</button>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@string.Join(", ", user.RoleIdHuyDds.Select(x => x.RoleName))</td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Locked</span>
                        }
                    </td>
                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@user.UserIdHuyDd" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="AssignRoles" asp-route-id="@user.UserIdHuyDd" class="btn btn-sm btn-outline-success">Roles</a>
                        <a asp-action="Edit" asp-route-id="@user.UserIdHuyDd" class="btn btn-sm btn-outline-primary">Edit</a>
                        <form asp-action="ToggleStatus" asp-route-id="@user.UserIdHuyDd" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-warning">@(user.IsActive ? "Lock" : "Unlock")</button>
                        </form>
                        <a asp-action="Delete" asp-route-id="@user.UserIdHuyDd" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
