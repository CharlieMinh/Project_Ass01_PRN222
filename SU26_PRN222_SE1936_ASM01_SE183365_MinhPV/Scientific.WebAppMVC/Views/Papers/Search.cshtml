@model PaperSearchViewModel

@{
    ViewData["Title"] = "Search Papers";
    var hasFilter = !string.IsNullOrWhiteSpace(Model.SearchText)
        || !string.IsNullOrWhiteSpace(Model.AuthorName)
        || Model.JournalId.HasValue
        || Model.PublicationYear.HasValue;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Search Papers</h1>
</div>

<form asp-action="Search" method="get" class="border rounded p-3 mb-4 bg-light">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label asp-for="SearchText" class="form-label">Search</label>
            <input asp-for="SearchText" class="form-control" placeholder="Title, abstract, or keyword..." />
        </div>
        <div class="col-md-3">
            <label asp-for="AuthorName" class="form-label">Author</label>
            <input asp-for="AuthorName" class="form-control" placeholder="Author name..." />
        </div>
        <div class="col-md-3">
            <label asp-for="JournalId" class="form-label">Journal</label>
            <select asp-for="JournalId" asp-items="Model.Journals" class="form-select">
                <option value="">-- All Journals --</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="PublicationYear" class="form-label">Year</label>
            <input asp-for="PublicationYear" type="number" class="form-control" placeholder="e.g. 2024" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
        <div class="col-auto">
            <a asp-action="Search" class="btn btn-outline-secondary">Reset</a>
        </div>
    </div>
</form>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (hasFilter && !Model.Results.Any())
{
    <div class="alert alert-info">No papers found.</div>
}

@if (Model.Results.Any())
{
    <div class="d-flex flex-column gap-3">
        @foreach (var paper in Model.Results)
        {
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between gap-3">
                        <div>
                            <h2 class="h5 mb-2">
                                <a asp-action="Details" asp-route-id="@paper.PaperId" class="text-decoration-none">
                                    @paper.Title
                                </a>
                            </h2>
                            <div class="text-muted small">
                                Journal: @(paper.JournalName ?? "N/A")
                                <span class="mx-1">|</span>
                                Year: @(paper.PublicationYear?.ToString() ?? "N/A")
                                <span class="mx-1">|</span>
                                Citations: @paper.CitationCount
                            </div>
                        </div>
                        @if (paper.IsOpenAccess)
                        {
                            <div>
                                <span class="badge text-bg-success">Open Access</span>
                            </div>
                        }
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@paper.PaperId" class="btn btn-sm btn-outline-primary">View Detail</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Bookmarks" asp-action="Add" asp-route-paperId="@paper.PaperId" method="post" class="d-inline">
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Bookmark</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
