@model PaperFormViewModel
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<input asp-for="PaperId" type="hidden" />
<div class="mb-3"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /><span asp-validation-for="Title" class="text-danger"></span></div>
<div class="mb-3"><label asp-for="Abstract" class="form-label"></label><textarea asp-for="Abstract" class="form-control" rows="4"></textarea></div>
<div class="row"><div class="col-md-4 mb-3"><label asp-for="Doi" class="form-label">DOI</label><input asp-for="Doi" class="form-control" /></div><div class="col-md-4 mb-3"><label asp-for="JournalId" class="form-label"></label><select asp-for="JournalId" asp-items="Model.JournalOptions" class="form-select"></select></div><div class="col-md-4 mb-3"><label asp-for="SourceName" class="form-label"></label><input asp-for="SourceName" class="form-control" /></div></div>
<div class="row"><div class="col-md-3 mb-3"><label asp-for="PublicationDate" class="form-label"></label><input asp-for="PublicationDate" class="form-control" /></div><div class="col-md-3 mb-3"><label asp-for="PublicationYear" class="form-label"></label><input asp-for="PublicationYear" class="form-control" /></div><div class="col-md-2 mb-3"><label asp-for="Volume" class="form-label"></label><input asp-for="Volume" class="form-control" /></div><div class="col-md-2 mb-3"><label asp-for="Issue" class="form-label"></label><input asp-for="Issue" class="form-control" /></div><div class="col-md-2 mb-3"><label asp-for="Pages" class="form-label"></label><input asp-for="Pages" class="form-control" /></div></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="PaperUrl" class="form-label"></label><input asp-for="PaperUrl" class="form-control" /></div><div class="col-md-6 mb-3"><label asp-for="PdfUrl" class="form-label"></label><input asp-for="PdfUrl" class="form-control" /></div></div>
<div class="form-check form-switch mb-3"><input asp-for="IsOpenAccess" class="form-check-input" /><label asp-for="IsOpenAccess" class="form-check-label"></label></div>
<button type="submit" class="btn btn-primary">Save</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
