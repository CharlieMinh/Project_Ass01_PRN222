@model PaperDetailViewModel

@{
    ViewData["Title"] = "Paper Details";
    var canManagePaper = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.Researcher);
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="d-flex align-items-center gap-2 mb-2">
            <h1 class="h3 mb-0">@Model.Title</h1>
            @if (Model.IsOpenAccess)
            {
                <span class="badge text-bg-success">Open Access</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.DOI))
        {
            <div class="text-muted">
                DOI:
                <a href="https://doi.org/@Model.DOI" target="_blank" rel="noopener noreferrer">@Model.DOI</a>
            </div>
        }
    </div>
    <div class="d-flex gap-2 flex-wrap justify-content-end">
        @if (canManagePaper)
        {
            <a asp-action="AssignAuthors" asp-route-id="@Model.PaperId" class="btn btn-sm btn-outline-success">Assign Authors</a>
            <a asp-action="AssignKeywords" asp-route-id="@Model.PaperId" class="btn btn-sm btn-outline-success">Assign Keywords</a>
            <a asp-action="Edit" asp-route-id="@Model.PaperId" class="btn btn-sm btn-outline-primary">Edit</a>
        }
        <a asp-action="Search" class="btn btn-sm btn-outline-secondary">Back to Search</a>
    </div>
</div>

<section class="mb-4">
    <h2 class="h5">Meta Info</h2>
    <dl class="row border rounded p-3 mb-0">
        <dt class="col-sm-3">Journal</dt>
        <dd class="col-sm-9">@(Model.JournalName ?? "N/A")</dd>

        <dt class="col-sm-3">Publisher</dt>
        <dd class="col-sm-9">@(Model.PublisherName ?? "N/A")</dd>

        <dt class="col-sm-3">Year</dt>
        <dd class="col-sm-9">@(Model.PublicationYear?.ToString() ?? "N/A")</dd>

        <dt class="col-sm-3">Date</dt>
        <dd class="col-sm-9">@(Model.PublicationDate?.ToString("yyyy-MM-dd") ?? "N/A")</dd>

        <dt class="col-sm-3">Volume / Issue</dt>
        <dd class="col-sm-9">@($"{Model.Volume ?? "N/A"} / {Model.Issue ?? "N/A"}")</dd>

        <dt class="col-sm-3">Pages</dt>
        <dd class="col-sm-9">@(Model.Pages ?? "N/A")</dd>

        <dt class="col-sm-3">Source</dt>
        <dd class="col-sm-9">@(Model.SourceName ?? "N/A")</dd>
    </dl>
</section>

<section class="mb-4">
    <h2 class="h5">Authors</h2>
    @if (Model.Authors.Any())
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var author in Model.Authors)
            {
                <span class="badge rounded-pill text-bg-secondary">@author</span>
            }
        </div>
    }
    else
    {
        <p class="text-muted mb-0">No authors assigned.</p>
    }
</section>

<section class="mb-4">
    <h2 class="h5">Keywords</h2>
    @if (Model.Keywords.Any())
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var keyword in Model.Keywords)
            {
                <span class="badge rounded-pill text-bg-info">@keyword</span>
            }
        </div>
    }
    else
    {
        <p class="text-muted mb-0">No keywords assigned.</p>
    }
</section>

<section class="mb-4">
    <h2 class="h5">Abstract</h2>
    <p class="mb-0">@(!string.IsNullOrWhiteSpace(Model.Abstract) ? Model.Abstract : "N/A")</p>
</section>

<section class="mb-4">
    <h2 class="h5">Metrics</h2>
    <div class="row g-3">
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Views</div>
                <div class="fs-4 fw-semibold">@Model.ViewCount</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Downloads</div>
                <div class="fs-4 fw-semibold">@Model.DownloadCount</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Bookmarks</div>
                <div class="fs-4 fw-semibold">@Model.BookmarkCount</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Citations</div>
                <div class="fs-4 fw-semibold">@Model.CitationCount</div>
            </div>
        </div>
    </div>
</section>

<section>
    <h2 class="h5">Actions</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (!string.IsNullOrWhiteSpace(Model.PaperUrl))
        {
            <a href="@Model.PaperUrl" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Read Paper</a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.PdfUrl))
        {
            <a href="@Model.PdfUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary">Download PDF</a>
        }
        @if (User.Identity?.IsAuthenticated == true)
        {
            <button type="button" class="btn btn-outline-secondary" disabled>
                @(Model.IsBookmarkedByCurrentUser ? "Bookmarked" : "Bookmark")
            </button>
        }
    </div>
</section>
