@model PapersBaoTg
@{ ViewData["Title"] = "Paper Details"; }
<div class="d-flex justify-content-between mb-3"><h1 class="h3">Paper Details</h1><div><a asp-action="AssignAuthors" asp-route-id="@Model.PaperIdBaoTg" class="btn btn-success">Assign Authors</a> <a asp-action="AssignKeywords" asp-route-id="@Model.PaperIdBaoTg" class="btn btn-success">Assign Keywords</a> <a asp-action="Edit" asp-route-id="@Model.PaperIdBaoTg" class="btn btn-primary">Edit</a> <a asp-action="Index" class="btn btn-outline-secondary">Back</a></div></div>
<dl class="row"><dt class="col-sm-3">Title</dt><dd class="col-sm-9">@Model.Title</dd><dt class="col-sm-3">Journal</dt><dd class="col-sm-9">@(Model.JournalIdMinhPvNavigation?.JournalName ?? "N/A")</dd><dt class="col-sm-3">DOI</dt><dd class="col-sm-9">@(Model.Doi ?? "N/A")</dd><dt class="col-sm-3">Publication</dt><dd class="col-sm-9">@($"{Model.PublicationDate?.ToString("yyyy-MM-dd") ?? "N/A"} / {Model.PublicationYear?.ToString() ?? "N/A"}")</dd><dt class="col-sm-3">Authors</dt><dd class="col-sm-9">@string.Join(", ", Model.PaperAuthorsBaoTgs.OrderBy(x => x.AuthorOrder).Select(x => x.AuthorIdBaoTgNavigation.FullName))</dd><dt class="col-sm-3">Keywords</dt><dd class="col-sm-9">@string.Join(", ", Model.Keywords.Select(x => x.KeywordName))</dd><dt class="col-sm-3">Abstract</dt><dd class="col-sm-9">@(Model.Abstract ?? "N/A")</dd></dl>
