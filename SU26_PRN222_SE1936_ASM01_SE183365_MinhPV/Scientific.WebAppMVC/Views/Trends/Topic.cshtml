@model TrendDetailViewModel

@{
    ViewData["Title"] = $"{Model.EntityName} Trend";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.EntityName</h1>
        <p class="text-muted mb-0">Topic trend detail</p>
    </div>
    <div class="d-flex flex-wrap gap-2 justify-content-end">
        @if (User.Identity?.IsAuthenticated == true)
        {
            if (Model.IsFollowedByCurrentUser)
            {
                <form asp-controller="Following" asp-action="UnfollowTopic" asp-route-topicId="@Model.EntityId" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button type="submit" class="btn btn-outline-danger">Unfollow Topic</button>
                </form>
            }
            else
            {
                <form asp-controller="Following" asp-action="FollowTopic" asp-route-topicId="@Model.EntityId" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button type="submit" class="btn btn-outline-secondary">Follow Topic</button>
                </form>
            }
        }
        <a asp-controller="Trends" asp-action="TrendingTopics" class="btn btn-outline-primary">Trending Topics</a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@await Html.PartialAsync("_TrendDetail", Model)
