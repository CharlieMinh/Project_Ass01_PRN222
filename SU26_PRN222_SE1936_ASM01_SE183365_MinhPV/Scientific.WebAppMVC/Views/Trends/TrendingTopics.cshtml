@model List<TrendingItemViewModel>

@{
    ViewData["Title"] = "Trending Topics";
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Trending Topics</h1>
        <p class="text-muted mb-0">Top topics and keywords ranked by trend score.</p>
    </div>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary">Dashboard</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No trend data available.</div>
}
else
{
    <div class="table-responsive border rounded">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Year</th>
                    <th class="text-end">Papers</th>
                    <th class="text-end">Citations</th>
                    <th class="text-end">Growth Rate</th>
                    <th class="text-end">Trend Score</th>
                    <th class="text-end">Detail</th>
                </tr>
            </thead>
            <tbody>
                @for (var index = 0; index < Model.Count; index++)
                {
                    var item = Model[index];
                    <tr>
                        <td>@(index + 1)</td>
                        <td class="fw-semibold">@item.Name</td>
                        <td>@item.Type</td>
                        <td>@item.RecordYear</td>
                        <td class="text-end">@item.PaperCount</td>
                        <td class="text-end">@item.CitationCount</td>
                        <td class="text-end">@item.GrowthRate.ToString("0.##")%</td>
                        <td class="text-end">@item.TrendScore.ToString("0.##")</td>
                        <td class="text-end">
                            @if (item.Type == "Topic")
                            {
                                <a asp-action="Topic" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            }
                            else
                            {
                                <a asp-action="Keyword" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
