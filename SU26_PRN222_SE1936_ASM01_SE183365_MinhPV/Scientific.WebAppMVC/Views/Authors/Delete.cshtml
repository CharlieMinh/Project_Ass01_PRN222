@model AuthorsBaoTg
@{ ViewData["Title"] = "Delete Author"; }
<h1 class="h3 text-danger">Delete Author</h1>
@if (Model.PaperAuthorsBaoTgs.Any()){<div class="alert alert-warning">This author is linked to @Model.PaperAuthorsBaoTgs.Count paper(s). Delete may be blocked.</div>}
<p>Delete <strong>@Model.FullName</strong>?</p>
<form asp-action="Delete" asp-route-id="@Model.AuthorIdBaoTg" method="post"><button class="btn btn-danger">Delete</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></form>
