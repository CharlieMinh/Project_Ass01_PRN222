@model AuthorsBaoTg
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<input asp-for="AuthorIdBaoTg" type="hidden" /><input asp-for="CreatedAt" type="hidden" />
<div class="row"><div class="col-md-6 mb-3"><label asp-for="FullName" class="form-label">Full name</label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="Affiliation" class="form-label"></label><input asp-for="Affiliation" class="form-control" /></div><div class="col-md-6 mb-3"><label asp-for="Country" class="form-label"></label><input asp-for="Country" class="form-control" /></div></div>
<div class="row"><div class="col-md-4 mb-3"><label asp-for="Orcid" class="form-label">ORCID</label><input asp-for="Orcid" class="form-control" /></div><div class="col-md-4 mb-3"><label asp-for="ScopusId" class="form-label">Scopus ID</label><input asp-for="ScopusId" class="form-control" /></div><div class="col-md-4 mb-3"><label asp-for="GoogleScholarUrl" class="form-label">Google Scholar URL</label><input asp-for="GoogleScholarUrl" class="form-control" /></div></div>
<button type="submit" class="btn btn-primary">Save</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
