@model CategoriesMinhPv
@{ ViewData["Title"] = "Category Details"; }
<div class="d-flex justify-content-between mb-3"><h1 class="h3">Category Details</h1><div><a asp-action="Edit" asp-route-id="@Model.CategoryIdMinhPv" class="btn btn-primary">Edit</a> <a asp-action="Index" class="btn btn-outline-secondary">Back</a></div></div>
<dl class="row"><dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.CategoryName</dd><dt class="col-sm-3">Description</dt><dd class="col-sm-9">@(Model.Description ?? "N/A")</dd><dt class="col-sm-3">Journals</dt><dd class="col-sm-9">@Model.JournalIdMinhPvs.Count</dd></dl>
