@model NotificationsIndexViewModel

@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Notifications</h1>
        <p class="text-muted mb-0">@Model.UnreadCount unread notification(s).</p>
    </div>
    @if (Model.UnreadCount > 0)
    {
        <form asp-action="MarkAllAsRead" method="post">
            <button type="submit" class="btn btn-outline-primary">Mark All as Read</button>
        </form>
    }
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.Notifications.Any())
{
    <div class="alert alert-info">You do not have any notifications yet.</div>
}
else
{
    <div class="list-group">
        @foreach (var item in Model.Notifications)
        {
            <div class="list-group-item @(item.IsRead ? "" : "list-group-item-primary")">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <h2 class="h6 mb-0">@item.Title</h2>
                            <span class="badge text-bg-secondary">@item.NotificationType</span>
                            @if (!item.IsRead)
                            {
                                <span class="badge text-bg-primary">Unread</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Message))
                        {
                            <p class="mb-2">@item.Message</p>
                        }
                        <div class="text-muted small">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="mt-2 d-flex flex-wrap gap-2">
                            @if (item.RelatedPaperId.HasValue)
                            {
                                <a asp-controller="Papers" asp-action="Details" asp-route-id="@item.RelatedPaperId" class="btn btn-sm btn-outline-primary">
                                    View Paper
                                </a>
                            }
                            @if (item.RelatedKeywordId.HasValue)
                            {
                                <a asp-controller="Trends" asp-action="Keyword" asp-route-id="@item.RelatedKeywordId" class="btn btn-sm btn-outline-secondary">
                                    Keyword Trend
                                </a>
                            }
                            @if (item.RelatedTopicId.HasValue)
                            {
                                <a asp-controller="Trends" asp-action="Topic" asp-route-id="@item.RelatedTopicId" class="btn btn-sm btn-outline-secondary">
                                    Topic Trend
                                </a>
                            }
                        </div>
                    </div>
                    @if (!item.IsRead)
                    {
                        <form asp-action="MarkAsRead" asp-route-id="@item.NotificationId" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-success">Mark Read</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}
