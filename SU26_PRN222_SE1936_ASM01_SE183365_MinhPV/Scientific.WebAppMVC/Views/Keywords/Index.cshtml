@model IEnumerable<KeywordsLuanNtk>
@{ ViewData["Title"] = "Keywords"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h3">Keywords</h1><a asp-action="Create" class="btn btn-primary">Create Keyword</a></div>
@if (TempData["SuccessMessage"] is string s){<div class="alert alert-success">@s</div>} @if (TempData["ErrorMessage"] is string e){<div class="alert alert-danger">@e</div>}
<form method="get" class="row g-2 mb-3"><div class="col-md-5"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search keyword" /></div><div class="col-auto"><button class="btn btn-outline-primary">Search</button></div><div class="col-auto"><a asp-action="Index" class="btn btn-outline-secondary">Reset</a></div></form>
<table class="table table-hover align-middle"><thead><tr><th>Name</th><th>Description</th><th class="text-end">Actions</th></tr></thead><tbody>
@foreach (var item in Model){<tr><td>@item.KeywordName</td><td>@(item.Description ?? "N/A")</td><td class="text-end"><a asp-action="Details" asp-route-id="@item.KeywordIdLuanNtk" class="btn btn-sm btn-outline-secondary">Details</a> <a asp-action="Edit" asp-route-id="@item.KeywordIdLuanNtk" class="btn btn-sm btn-outline-primary">Edit</a> <a asp-action="Delete" asp-route-id="@item.KeywordIdLuanNtk" class="btn btn-sm btn-outline-danger">Delete</a></td></tr>}
</tbody></table>
