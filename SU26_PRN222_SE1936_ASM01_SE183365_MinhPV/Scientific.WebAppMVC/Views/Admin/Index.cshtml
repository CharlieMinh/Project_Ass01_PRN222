@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">Admin Dashboard</h1>
        <p class="text-muted mb-0">System management area for project data and demo workflows.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <a asp-controller="JournalsMinhPvs" asp-action="Index" class="card text-decoration-none text-dark h-100">
            <div class="card-body">
                <h2 class="h6">Journals</h2>
                <p class="text-muted mb-0">Manage journal data.</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6">Papers</h2>
                <p class="text-muted mb-0">Coming in the core CRUD milestone.</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6">Keywords</h2>
                <p class="text-muted mb-0">Coming in the keyword/topic milestone.</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6">Users</h2>
                <p class="text-muted mb-0">Coming in the admin CRUD milestone.</p>
            </div>
        </div>
    </div>
</div>
